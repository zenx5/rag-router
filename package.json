{
  "name": "rag-router",
  "version": "0.0.4",
  "description": "",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/adapters/index.ts src/adapters/db/index.ts src/adapters/db/chroma.ts src/adapters/db/typesense.ts src/adapters/models/index.ts src/adapters/models/openai.ts --format cjs,esm --dts --out-dir dist",
    "prepublishOnly": "npm run build",
    "test": "node --watch playground/server.ts",
    "test2": "node --watch playground/server2.ts"
  },
  "keywords": [],
  "author": "Octavio Martinez (https://github.com/zenx5)",
  "license": "ISC",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs",
      "types": "./dist/adapters/index.d.ts"
    },
    "./adapters/db": {
      "import": "./dist/adapters/db/index.js",
      "require": "./dist/adapters/db/index.cjs",
      "types": "./dist/adapters/db/index.d.ts"
    },
    "./adapters/models": {
      "import": "./dist/adapters/models/index.js",
      "require": "./dist/adapters/models/index.cjs",
      "types": "./dist/adapters/models/index.d.ts"
    },
    "./adapters/db/chroma": {
      "import": "./dist/adapters/db/chroma.js",
      "require": "./dist/adapters/db/chroma.cjs",
      "types": "./dist/adapters/db/chroma.d.ts"
    },
    "./adapters/db/typesense": {
      "import": "./dist/adapters/db/typesense.js",
      "require": "./dist/adapters/db/typesense.cjs",
      "types": "./dist/adapters/db/typesense.d.ts"
    },
    "./adapters/models/openai": {
      "import": "./dist/adapters/models/openai.js",
      "require": "./dist/adapters/models/openai.cjs",
      "types": "./dist/adapters/models/openai.d.ts"
    }
  },
  "dependencies": {
    "chromadb": "3.4.3",
    "express": "5.2.1",
    "openai": "6.38.0",
    "typesense": "3.0.6"
  },
  "devDependencies": {
    "tsup": "^6.6.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "@types/express": "5.0.6"
  }
}
